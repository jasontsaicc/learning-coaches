# skills/*/workspace/ is untracked scratch; workspaces/ (top-level) is
# git-TRACKED learner state, synced across machines
skills/*/workspace/
*-coach-workspace/

# lab scratch and cluster credentials never get committed
workspaces/k8s/labs/*
!workspaces/k8s/labs/.gitkeep
*.kubeconfig

# sd PoC build artifacts stay out of git (source, Dockerfile, compose are tracked)
portfolio/sd/projects/**/bin/
portfolio/sd/projects/day23-rate-limiter/day23-rate-limiter
portfolio/sd/projects/**/*.test

# leetcode lab pytest scratch (lab-lc.sh teardown also clears these)
__pycache__/
.pytest_cache/
